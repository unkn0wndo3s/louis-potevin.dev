<script>
  import { scrub, clamp01, window01 } from '../lib/scrub';
  import { getSmooth } from '../lib/smooth';

  const doc = document.querySelector<HTMLElement>('[data-doc]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---- Focus mode: one chapter sharp, the rest dimmed --------------------
  const links = new Map(
    Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc]')).map((a) => [a.dataset.toc!, a]),
  );
  const chapters = Array.from(document.querySelectorAll<HTMLElement>('.ch'));
  const obs = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        chapters.forEach((c) => c.classList.toggle('is-focus', c === e.target));
        links.forEach((a) => a.classList.remove('is-active'));
        links.get(e.target.id)?.classList.add('is-active');
      }
    },
    { rootMargin: '-35% 0px -35% 0px' },
  );
  chapters.forEach((c) => obs.observe(c));
  if (!reduced) doc?.classList.add('focus-on');

  // ---- Demos (all skipped under reduced motion) ---------------------------
  if (!reduced && doc) {
    doc.classList.add('is-live');
    const $ = <T extends HTMLElement | SVGElement>(sel: string) => document.querySelector<T>(sel);

    // 01 · live page progress
    {
      const val = $('[data-p-val]');
      const fill = $<HTMLElement>('[data-p-fill]');
      const loop = () => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = clamp01((getSmooth()?.scroll ?? window.scrollY) / Math.max(1, max));
        if (val) val.textContent = p.toFixed(3);
        if (fill) fill.style.transform = `scaleX(${p})`;
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }

    // 02 · raw vs lerp
    {
      const root = $<HTMLElement>('[data-demo-lerp]');
      const raw = $<HTMLElement>('[data-dot-raw]');
      const smooth = $<HTMLElement>('[data-dot-smooth]');
      if (root && raw && smooth) {
        root.classList.add('is-ready');
        let target = 0;
        let pos = 0;
        scrub(root, (p) => (target = p));
        const loop = () => {
          pos += (target - pos) * 0.09;
          raw.style.left = `${(target * 100).toFixed(2)}%`;
          smooth.style.left = `${(pos * 100).toFixed(2)}%`;
          requestAnimationFrame(loop);
        };
        requestAnimationFrame(loop);
      }
    }

    // 03 · scrub meter
    {
      const root = $<HTMLElement>('[data-demo-scrub]');
      const ring = $<SVGCircleElement>('[data-ring]');
      const val = $('[data-scrub-val]');
      const stage = $<HTMLElement>('[data-md-stage]');
      if (root && ring && val && stage) {
        root.classList.add('is-ready');
        scrub(root, (p) => {
          ring.style.strokeDashoffset = String(1 - p);
          val.textContent = p.toFixed(2);
          stage.style.top = `${(p * 62).toFixed(1)}%`;
        });
      }
    }

    // 04 · camera on a curve
    {
      const root = $<HTMLElement>('[data-demo-curve]');
      const path = $<SVGPathElement>('[data-curve-path]');
      const cam = $<SVGCircleElement>('[data-cam]');
      const look = $<SVGCircleElement>('[data-look]');
      const gaze = $<SVGLineElement>('[data-gaze]');
      const beacons = Array.from(document.querySelectorAll<SVGCircleElement>('[data-beacon]'));
      if (root && path && cam && look && gaze) {
        root.classList.add('is-ready');
        const len = path.getTotalLength();
        beacons.forEach((b) => {
          const pt = path.getPointAtLength(Number(b.dataset.beacon) * len);
          b.setAttribute('cx', String(pt.x));
          b.setAttribute('cy', String(pt.y));
        });
        scrub(root, (p) => {
          const a = path.getPointAtLength(p * len);
          const b = path.getPointAtLength(Math.min(1, p + 0.045) * len);
          cam.setAttribute('cx', String(a.x));
          cam.setAttribute('cy', String(a.y));
          look.setAttribute('cx', String(b.x));
          look.setAttribute('cy', String(b.y));
          gaze.setAttribute('x1', String(a.x));
          gaze.setAttribute('y1', String(a.y));
          gaze.setAttribute('x2', String(b.x));
          gaze.setAttribute('y2', String(b.y));
          path.style.strokeDashoffset = String(1 - p);
          beacons.forEach((bc) => {
            const d = Math.abs(Number(bc.dataset.beacon) - p);
            bc.style.opacity = String(0.3 + clamp01(1 - d * 6) * 0.7);
            bc.style.transform = `scale(${1 + clamp01(1 - d * 6) * 0.6})`;
          });
        });
      }
    }

    // 05 · overlay windows
    {
      const root = $<HTMLElement>('[data-demo-overlay]');
      const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-panel]'));
      const head = $<HTMLElement>('[data-tl-head]');
      const windows: [number, number][] = [
        [0, 0.4],
        [0.3, 0.7],
        [0.6, 1],
      ];
      if (root && panels.length && head) {
        root.classList.add('is-ready');
        scrub(root, (p) => {
          panels.forEach((el, i) => {
            const [a, b] = windows[i]!;
            const local = clamp01((p - a) / (b - a));
            const vis = Math.min(i === 0 ? 1 : window01(local, 0.05, 0.3), i === panels.length - 1 ? 1 : 1 - window01(local, 0.7, 0.95));
            el.style.opacity = String(vis);
            el.style.transform = `translateY(${((1 - vis) * 22).toFixed(1)}px)`;
          });
          head.style.left = `${(p * 100).toFixed(2)}%`;
        });
      }
    }

    // 06 · velocity particles (reads the real Lenis velocity)
    {
      const canvas = $<HTMLCanvasElement>('[data-velo]');
      const vVal = $('[data-velo-val]');
      const dVal = $('[data-velo-down]');
      const uVal = $('[data-velo-up]');
      const ctx = canvas?.getContext('2d');
      if (canvas && ctx) {
        canvas.closest('[data-demo-velocity]')?.classList.add('is-ready');
        const css = getComputedStyle(document.documentElement);
        const CYAN = css.getPropertyValue('--nds-primary').trim() || '#2efafa';
        const N = 42;
        interface P { bx: number; by: number; x: number; y: number; vx: number; vy: number }
        let parts: P[] = [];
        let W = 0;
        let H = 0;
        const size = () => {
          W = canvas.clientWidth;
          H = canvas.clientHeight;
          canvas.width = W * devicePixelRatio;
          canvas.height = H * devicePixelRatio;
          ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
          parts = Array.from({ length: N }, (_, i) => {
            const a = (i / N) * Math.PI * 2;
            const r = Math.min(W, H) * 0.32;
            const bx = W / 2 + Math.cos(a) * r;
            const by = H / 2 + Math.sin(a) * r * 0.8;
            return { bx, by, x: bx, y: by, vx: (Math.random() - 0.5) * 60, vy: (Math.random() - 0.5) * 60 };
          });
        };
        size();
        window.addEventListener('resize', size);
        let down = 0;
        let up = 0;
        let last = performance.now();
        const loop = (now: number) => {
          const dt = Math.min((now - last) / 1000, 0.05);
          last = now;
          const v = getSmooth()?.velocity ?? 0;
          down += (clamp01(v / 55) - down) * 0.08;
          up += (clamp01(-v / 55) - up) * 0.08;
          if (vVal) vVal.textContent = v.toFixed(0);
          if (dVal) dVal.textContent = down.toFixed(2);
          if (uVal) uVal.textContent = up.toFixed(2);
          ctx.clearRect(0, 0, W, H);
          ctx.fillStyle = CYAN;
          for (const p of parts) {
            if (down > 0.04) {
              p.x += p.vx * dt * down * 3;
              p.y += p.vy * dt * down * 3;
            }
            if (up > 0.04) {
              const dx = W / 2 - p.x;
              const dy = H / 2 - p.y;
              p.x += (-dy * 0.9 + dx * 0.7) * dt * up * 2.2;
              p.y += (dx * 0.9 + dy * 0.7) * dt * up * 2.2;
            }
            if (down <= 0.04 && up <= 0.04) {
              p.x += (p.bx - p.x) * dt * 1.6;
              p.y += (p.by - p.y) * dt * 1.6;
            }
            // keep them on the board
            p.x = Math.max(4, Math.min(W - 4, p.x));
            p.y = Math.max(4, Math.min(H - 4, p.y));
            ctx.globalAlpha = 0.85;
            ctx.beginPath();
            ctx.arc(p.x, p.y, 2.4, 0, Math.PI * 2);
            ctx.fill();
          }
          requestAnimationFrame(loop);
        };
        requestAnimationFrame(loop);
      }
    }

    // 07 · pathLength draw
    {
      const root = $<HTMLElement>('[data-demo-draw]');
      const paths = Array.from(document.querySelectorAll<SVGPathElement>('[data-draw-path]'));
      const val = $('[data-draw-val]');
      if (root && paths.length) {
        root.classList.add('is-ready');
        scrub(root, (p) => {
          const off = 1 - window01(p, 0.05, 0.9);
          paths.forEach((el, i) => {
            el.style.strokeDashoffset = String(i === 0 ? off : 1 - window01(p, 0.55, 0.9));
          });
          if (val) val.textContent = off.toFixed(2);
        });
      }
    }

    // 08 · mini sorter (reversed FLIP, same recipe as the real scene)
    {
      const root = $<HTMLElement>('[data-demo-sort]');
      const board = $<HTMLElement>('[data-mini-board]');
      const chips = Array.from(document.querySelectorAll<HTMLElement>('[data-mini-chip]'));
      if (root && board && chips.length) {
        root.classList.add('is-ready');
        const seeded = (i: number) => {
          const x = Math.sin(i * 127.1 + 311.7) * 43758.5453;
          return x - Math.floor(x);
        };
        interface It { el: HTMLElement; tx: number; ty: number; sx: number; sy: number; rot: number }
        let items: It[] = [];
        const measure = () => {
          root.classList.remove('is-sorting');
          board.style.height = '';
          chips.forEach((c) => c.removeAttribute('style'));
          const b = board.getBoundingClientRect();
          board.style.height = `${b.height}px`;
          items = chips.map((el, i) => {
            const r = el.getBoundingClientRect();
            return {
              el,
              tx: r.left - b.left,
              ty: r.top - b.top,
              sx: seeded(i) * (b.width - r.width),
              sy: seeded(i + 40) * (b.height - r.height),
              rot: (seeded(i + 80) - 0.5) * 30,
            };
          });
          root.classList.add('is-sorting');
        };
        measure();
        let rt = 0;
        window.addEventListener('resize', () => {
          window.clearTimeout(rt);
          rt = window.setTimeout(measure, 150);
        });
        scrub(root, (p) => {
          for (let i = 0; i < items.length; i++) {
            const it = items[i]!;
            const e = window01(p, 0.1 + i * 0.07, 0.55 + i * 0.07);
            const x = it.sx + (it.tx - it.sx) * e;
            const y = it.sy + (it.ty - it.sy) * e - Math.sin(e * Math.PI) * 26;
            it.el.style.transform = `translate(${x.toFixed(1)}px, ${y.toFixed(1)}px) rotate(${(it.rot * (1 - e)).toFixed(1)}deg)`;
          }
        });
      }
    }
  }
</script>

